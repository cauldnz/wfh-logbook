# WFH Logbook configuration.
# Copy this file to `.env` and fill in values. NEVER commit `.env`.

# ----------------------------------------------------------- UniFi controller
UNIFI_HOST=                  # e.g. https://192.168.1.1
UNIFI_SITE=default
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_VERIFY_TLS=false       # most home controllers use self-signed certs
UNIFI_API_FLAVOUR=auto       # auto | udm | classic

# ----------------------------------------------------- Work SSID and devices
WORK_SSID=
# Comma-separated MAC=Label pairs. Use the per-SSID private MAC for iOS.
WORK_DEVICE_MACS=            # e.g. aa:bb:cc:dd:ee:ff=iPhone,11:22:33:44:55:66=Laptop

# ---------------------------------------- Sessionisation defaults (seed only)
# These seed the `config` table on first run. After that the DB is the
# source of truth and `.env` changes here are ignored (a warning is logged).
GAP_BRIDGE_MINUTES=10
MIN_SESSION_MINUTES=2
DAILY_CAP_HOURS=12
LOCAL_TIMEZONE=Australia/Sydney
RULE_VERSION=2026.1

# -------------------------------------------------------------------- Service
HTTP_HOST=0.0.0.0
HTTP_PORT=8088
POLL_INTERVAL_SECONDS=60
DATA_DIR=/data
LOG_LEVEL=INFO

# ----------------------------------------------------- Telegram bot (Phase 7)
TELEGRAM_BOT_TOKEN=                            # leave empty to disable the bot
TELEGRAM_MODE=webhook                          # webhook | polling
TELEGRAM_ALLOWED_USER_IDS=                     # comma-separated numeric IDs
TELEGRAM_WEBHOOK_SECRET=                       # random string; part of webhook URL
PUBLIC_BASE_URL=                               # e.g. https://wfh.example.com

# ---------------------- Cloudflare Tunnel (only needed in webhook mode)
CLOUDFLARE_TUNNEL_TOKEN=
